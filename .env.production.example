# ─────────────────────────────────────────────────────────────────────────────
# Proofdesk Production Environment
#
# 1. Copy:   cp .env.production.example .env.production
# 2. Fill in GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET, and PROOFDESK_SESSION_SECRET
# 3. Deploy:
#      AWS:  ./scripts/aws/full-deploy.sh
#      OCI:  OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxx ./scripts/oci/full-deploy.sh
#
# FRONTEND_URL and GITHUB_REDIRECT_URI are patched automatically by the
# deploy script once it knows the server IP.
# ─────────────────────────────────────────────────────────────────────────────

# Public URL that serves the React app and proxies backend routes through nginx.
FRONTEND_URL=https://proofdesk.example.com

# GitHub OAuth app for production.
GITHUB_CLIENT_ID=fill_from_github_oauth_app
GITHUB_CLIENT_SECRET=fill_from_github_oauth_app
GITHUB_REDIRECT_URI=https://proofdesk.example.com/auth/github/callback

# Generate with: openssl rand -hex 32
PROOFDESK_SESSION_SECRET=fill_with_a_long_random_secret

# Optional token for deployment smoke checks or prewarming private repositories.
GITHUB_PERSONAL_TOKEN=

# Optional repository prewarming. Use owner/repo or full GitHub URLs.
PREWARM_REPOS=QBobWatson/ila
PROOFDESK_SMOKE_REPO=QBobWatson/ila

# Monitoring is stored locally; webhook URL is optional.
PROOFDESK_MONITORING_ENABLED=true
PROOFDESK_MONITORING_WEBHOOK_URL=
