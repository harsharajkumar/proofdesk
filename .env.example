# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create one at https://github.com/settings/developers → "New OAuth App"
# Dev  Homepage URL:  http://localhost:3000
# Dev  Callback URL:  http://localhost:4000/auth/github/callback
# Prod Homepage URL:  https://yourdomain.com
# Prod Callback URL:  https://yourdomain.com/auth/github/callback
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback

# ── URLs ──────────────────────────────────────────────────────────────────────
# In production: FRONTEND_URL=https://yourdomain.com
#                GITHUB_REDIRECT_URI=https://yourdomain.com/auth/github/callback
#                ENABLE_LOCAL_TEST_MODE=false
FRONTEND_URL=http://localhost:3000
# Vite prefix required — this is what the React frontend reads
VITE_BACKEND_URL=http://localhost:4000
VITE_ENABLE_LOCAL_TEST_MODE=false
VITE_LOCAL_TEST_TOKEN=local-test
VITE_LOCAL_TEST_REPO_OWNER=demo
VITE_LOCAL_TEST_REPO_NAME=course-demo

# Backend server port
PORT=4000

# Optional: personal access token for testing without OAuth
GITHUB_PERSONAL_TOKEN=
PROOFDESK_SMOKE_REPO=QBobWatson/ila

# ── Local test mode ───────────────────────────────────────────────────────────
# Lets you exercise the full editor, build preview, and collaboration flow
# without signing in to GitHub.
# Keep this disabled for staging/production deployments.
ENABLE_LOCAL_TEST_MODE=false
LOCAL_TEST_TOKEN=local-test
LOCAL_TEST_REPO_OWNER=demo
LOCAL_TEST_REPO_NAME=course-demo
LOCAL_TEST_REPO_PATH=./test-repo/course-demo

# ── Deployment runtime ────────────────────────────────────────────────────────
# For staging/production, start from:
#   backend/.env.production.example
#   frontend/.env.production.example
PROOFDESK_SESSION_SECRET=replace_me
PROOFDESK_DATA_DIR=./.proofdesk-data
PROOFDESK_TERMINAL_MODE=restricted
PROOFDESK_TERMINAL_RUNTIME=container
PROOFDESK_SHARED_STATE_BACKEND=redis
PROOFDESK_REDIS_URL=redis://redis:6379/0
PROOFDESK_MONITORING_ENABLED=true
PROOFDESK_MONITORING_WEBHOOK_URL=

# ── Build cache pre-warming ───────────────────────────────────────────────────
# Repos to build automatically at server startup so the first visitor sees
# results instantly. Accepts full GitHub URLs or short owner/repo format.
# Both forms work:
#   PREWARM_REPOS=QBobWatson/ila
#   PREWARM_REPOS=https://github.com/QBobWatson/ila
#   PREWARM_REPOS=https://github.com/QBobWatson/ila,owner2/repo2
PREWARM_REPOS=https://github.com/QBobWatson/ila

# ── ILA Textbook (only needed for the ila-live service) ───────────────────────
ILA_REPO_PATH=./builds/ila-repo
