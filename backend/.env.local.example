GITHUB_CLIENT_ID=your_real_client_id
GITHUB_CLIENT_SECRET=your_real_client_secret
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback
FRONTEND_URL=http://localhost:3000
PORT=4000
BACKEND_URL=http://localhost:4000
GITHUB_PERSONAL_TOKEN=

# Google OAuth (optional — allows sign-in without a GitHub account)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:4000/auth/google/callback as an Authorized Redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Email notifications (optional — notifies users when their build completes)
# Option A: SendGrid (set SENDGRID_API_KEY only)
SENDGRID_API_KEY=
# Option B: Generic SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@proofdesk.app

PROOFDESK_SMOKE_REPO=QBobWatson/ila
ENABLE_LOCAL_TEST_MODE=false
PROOFDESK_SESSION_SECRET=choose_a_long_random_local_secret
PROOFDESK_DATA_DIR=./.proofdesk-data
PROOFDESK_TERMINAL_MODE=restricted
PROOFDESK_TERMINAL_RUNTIME=process
PROOFDESK_SHARED_STATE_BACKEND=filesystem
PROOFDESK_MONITORING_ENABLED=true
PROOFDESK_MONITORING_WEBHOOK_URL=
LOCAL_TEST_TOKEN=local-test
LOCAL_TEST_REPO_OWNER=demo
LOCAL_TEST_REPO_NAME=course-demo
LOCAL_TEST_REPO_PATH=./test-repo/course-demo
