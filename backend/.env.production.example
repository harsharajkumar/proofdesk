GITHUB_CLIENT_ID=fill_from_deployment_secret
GITHUB_CLIENT_SECRET=fill_from_deployment_secret
GITHUB_REDIRECT_URI=https://proofdesk.example.com/auth/github/callback
FRONTEND_URL=https://proofdesk.example.com
PORT=4000
BACKEND_URL=https://api.proofdesk.example.com
GITHUB_PERSONAL_TOKEN=
ENABLE_LOCAL_TEST_MODE=false
PROOFDESK_SESSION_SECRET=fill_with_a_long_random_secret
PROOFDESK_DATA_DIR=/var/lib/proofdesk
PROOFDESK_TERMINAL_MODE=restricted
PROOFDESK_TERMINAL_RUNTIME=container
PROOFDESK_SHARED_STATE_BACKEND=redis
PROOFDESK_REDIS_URL=redis://redis:6379/0
PROOFDESK_MONITORING_ENABLED=true
PROOFDESK_MONITORING_WEBHOOK_URL=
PREWARM_REPOS=QBobWatson/ila
PROOFDESK_SMOKE_REPO=QBobWatson/ila
