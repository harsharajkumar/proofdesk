# Nginx image using a locally pre-built frontend dist/ (no Node build step).
# Used when deploying to memory-constrained hosts where npm run build would swap.
FROM nginx:alpine

RUN apk add --no-cache openssl

RUN rm /etc/nginx/conf.d/default.conf

COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY docker/nginx-entrypoint.sh /docker-entrypoint-custom.sh
RUN chmod +x /docker-entrypoint-custom.sh
COPY frontend/dist /app/frontend

EXPOSE 80 443
ENTRYPOINT ["/docker-entrypoint-custom.sh"]
